<section class="panel">
  <h1><%= settings.about_title || "About OTR Life" %></h1>
  <p class="muted"><%= settings.tagline || "" %></p>

  <% if (settings.about_image_url) { %>
    <img src="<%= settings.about_image_url %>" alt="<%= settings.about_title %>" class="about-image" />
  <% } %>

  <div class="markdown">
    <%- aboutBodyHtml %>
  </div>

  <div class="about-contact-box">
    <p><strong>Questions? Feedback?</strong> <a href="/contact">Get in touch</a>.</p>
  </div>
</section>
