<section class="panel">
  <h1>Multi-Stop Mileage Calculator</h1>
  <p class="muted">
    Enter cities, states, or ZIP codes to get real driving miles across multiple stops.
    Add as many stops as you need — it calculates each leg and the total.
  </p>
</section>

<section class="card">
  <div id="stops" class="stack" style="margin-bottom:1rem;"></div>

  <div class="row gap" style="margin-bottom:1rem;">
    <button class="btn btn-outline" id="addStop" type="button">+ Add Stop</button>
    <button class="btn" id="calc" type="button">Calculate Miles</button>
  </div>

  <p id="status" class="small muted"></p>
  <div id="output"></div>
</section>

<section class="card">
  <h2>Tips</h2>
  <p><strong>What format should I use?</strong><br />City and state works best (e.g., "Dallas, TX"). ZIP codes and full addresses also work.</p>
  <p><strong>How accurate is it?</strong><br />Miles come from real road routing data, so they reflect actual driving distance — not straight-line miles.</p>
  <p><strong>Can I add more than two stops?</strong><br />Yes. Hit "Add Stop" for each additional waypoint. The tool calculates every leg and adds them up.</p>
  <p><strong>Does it account for my specific route?</strong><br />It finds the fastest car route between each stop. Truck-restricted roads may differ slightly.</p>
</section>

<style>
  .stop-wrap { position: relative; flex: 1; }
  #stops .row { display: flex; gap: .5rem; align-items: flex-start; }
  #stops .row button { white-space: nowrap; margin-top: 2px; }
  #output ul { padding-left: 1.2rem; margin: .5rem 0 0; }
  #output li { margin-bottom: .25rem; }
  #status.error { color: var(--color-danger, #e55); }

  .ac-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--color-surface, #1e1e1e);
    border: 1px solid var(--color-border, #444);
    border-top: none;
    border-radius: 0 0 6px 6px;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(0,0,0,.45);
  }
  .ac-dropdown li {
    list-style: none;
    padding: .5rem .75rem;
    font-size: .9rem;
    cursor: pointer;
    border-bottom: 1px solid var(--color-border, #333);
    line-height: 1.3;
  }
  .ac-dropdown li:last-child { border-bottom: none; }
  .ac-dropdown li:hover,
  .ac-dropdown li.ac-active { background: var(--color-primary, #c8952a); color: #fff; }
  .ac-dropdown li .ac-sub { font-size: .78rem; opacity: .75; display: block; margin-top: 1px; }
</style>

<script>
(function () {

const NOMINATIM_URL = "https://nominatim.openstreetmap.org/search";
const OSRM_URL      = "https://router.project-osrm.org/route/v1/driving";
const AC_DEBOUNCE   = 350;
const AC_MIN_CHARS  = 2;
const AC_LIMIT      = 6;

function milesFromMeters(m) { return m / 1609.344; }
function fmtMiles(mi) { return `${mi.toFixed(1)} mi`; }

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]));
}

function setStatus(msg, isError) {
  const el = document.getElementById("status");
  el.textContent = msg;
  el.className = "small" + (isError ? " error" : " muted");
}

function renderOutput(html) {
  document.getElementById("output").innerHTML = html;
}

function shortLabel(displayName) {
  if (!displayName) return displayName;
  const parts = displayName.split(",").map(function (p) { return p.trim(); });
  if (parts.length >= 2) {
    return parts[0] + ", " + parts[1];
  }
  return parts[0];
}

function isZip(raw) {
  return /^\d{5}(-\d{4})?$/.test(raw.trim());
}

async function nominatimSearch(raw, limit) {
  const q = isZip(raw) ? raw.trim() : raw.trim() + ", USA";
  const url = new URL(NOMINATIM_URL);
  url.searchParams.set("q", q);
  url.searchParams.set("format", "json");
  url.searchParams.set("limit", String(limit || 1));
  url.searchParams.set("countrycodes", "us");
  const res = await fetch(url.toString(), { headers: { Accept: "application/json" } });
  if (!res.ok) throw new Error("Location lookup failed");
  return res.json();
}

async function geocode(raw) {
  if (!raw.trim()) throw new Error("Empty stop");
  const data = await nominatimSearch(raw, 1);
  if (!Array.isArray(data) || !data.length) throw new Error(`Could not find location: "${raw}"`);
  return { query: raw.trim(), lat: Number(data[0].lat), lon: Number(data[0].lon) };
}

async function routeMeters(a, b) {
  const coords = `${a.lon},${a.lat};${b.lon},${b.lat}`;
  const url = `${OSRM_URL}/${coords}?overview=false&alternatives=false&steps=false`;
  const res = await fetch(url, { headers: { Accept: "application/json" } });
  if (!res.ok) throw new Error(`Routing failed: "${a.query}" to "${b.query}"`);
  const data = await res.json();
  if (!data || data.code !== "Ok" || !data.routes || !data.routes.length) {
    throw new Error(`No route found: "${a.query}" to "${b.query}"`);
  }
  return data.routes[0].distance;
}

const sleep = function (ms) { return new Promise(function (r) { setTimeout(r, ms); }); };

function closeAllDropdowns(except) {
  document.querySelectorAll(".ac-dropdown").forEach(function (dd) {
    if (dd !== except) dd.remove();
  });
}

document.addEventListener("mousedown", function (e) {
  if (!e.target.closest(".stop-wrap")) closeAllDropdowns(null);
});

function attachAutocomplete(input) {
  var timer = null;
  var activeIndex = -1;

  function getDropdown() {
    return input.parentElement.querySelector(".ac-dropdown");
  }

  function removeDropdown() {
    var dd = getDropdown();
    if (dd) dd.remove();
    activeIndex = -1;
  }

  function buildDropdown(results) {
    removeDropdown();
    if (!results.length) return;

    var ul = document.createElement("ul");
    ul.className = "ac-dropdown";

    results.forEach(function (hit, idx) {
      var li = document.createElement("li");
      var main = shortLabel(hit.display_name);
      var sub = hit.display_name !== main ? hit.display_name : "";
      li.innerHTML = escapeHtml(main) + (sub ? '<span class="ac-sub">' + escapeHtml(sub) + "</span>" : "");

      li.addEventListener("mousedown", function (e) {
        e.preventDefault();
        input.value = main;
        input._coords = { lat: Number(hit.lat), lon: Number(hit.lon), query: main };
        removeDropdown();
        input.focus();
      });

      ul.appendChild(li);
    });

    input.parentElement.appendChild(ul);
    activeIndex = -1;
  }

  function highlight(newIndex) {
    var dd = getDropdown();
    if (!dd) return;
    var items = dd.querySelectorAll("li");
    items.forEach(function (li, i) {
      li.classList.toggle("ac-active", i === newIndex);
    });
    activeIndex = newIndex;
  }

  input.addEventListener("input", function () {
    delete input._coords;
    var val = input.value.trim();
    clearTimeout(timer);
    if (val.length < AC_MIN_CHARS) { removeDropdown(); return; }
    timer = setTimeout(async function () {
      try {
        var results = await nominatimSearch(val, AC_LIMIT);
        if (input.value.trim() === val) buildDropdown(results || []);
      } catch (_) { removeDropdown(); }
    }, AC_DEBOUNCE);
  });

  input.addEventListener("keydown", function (e) {
    var dd = getDropdown();
    if (!dd) return;
    var items = dd.querySelectorAll("li");
    if (e.key === "ArrowDown") {
      e.preventDefault();
      highlight(Math.min(activeIndex + 1, items.length - 1));
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      highlight(Math.max(activeIndex - 1, 0));
    } else if (e.key === "Enter" && activeIndex >= 0) {
      e.preventDefault();
      items[activeIndex].dispatchEvent(new MouseEvent("mousedown", { bubbles: true }));
    } else if (e.key === "Escape") {
      removeDropdown();
    }
  });

  input.addEventListener("blur", function () {
    setTimeout(removeDropdown, 150);
  });
}

let stopCount = 0;

function addStop(value) {
  stopCount += 1;

  const row = document.createElement("div");
  row.className = "row";
  row.dataset.stopRow = "1";

  const wrap = document.createElement("div");
  wrap.className = "stop-wrap";

  const input = document.createElement("input");
  input.type = "text";
  input.placeholder = stopCount === 1 ? "Start (city/state or ZIP)" :
                      stopCount === 2 ? "Destination" :
                      `Stop ${stopCount}`;
  input.value = value || "";

  wrap.appendChild(input);
  attachAutocomplete(input);

  const remove = document.createElement("button");
  remove.type = "button";
  remove.textContent = "Remove";
  remove.className = "btn btn-sm btn-outline";
  remove.addEventListener("click", function () {
    row.remove();
    renumber();
  });

  row.appendChild(wrap);
  row.appendChild(remove);
  document.getElementById("stops").appendChild(row);
  updateRemove();
}

function getInputs() {
  return Array.from(document.querySelectorAll('[data-stop-row="1"] input'));
}

function updateRemove() {
  const rows = Array.from(document.querySelectorAll('[data-stop-row="1"]'));
  const can = rows.length > 2;
  rows.forEach(function (row) {
    const btn = row.querySelector("button");
    btn.disabled = !can;
    btn.style.opacity = can ? "1" : "0.4";
    btn.style.cursor  = can ? "pointer" : "not-allowed";
  });
}

function renumber() {
  const inputs = getInputs();
  inputs.forEach(function (inp, idx) {
    if (idx === 0) inp.placeholder = "Start (city/state or ZIP)";
    else if (idx === inputs.length - 1) inp.placeholder = "Destination";
    else inp.placeholder = `Stop ${idx + 1}`;
  });
  updateRemove();
}

async function calculate() {
  closeAllDropdowns(null);
  renderOutput("");
  setStatus("Working\u2026", false);

  const inputs = getInputs();
  const filled = inputs.filter(function (i) { return i.value.trim(); });
  if (filled.length < 2) {
    setStatus("Add at least a start and one destination.", true);
    return;
  }

  try {
    const points = [];
    for (var i = 0; i < filled.length; i++) {
      const inp = filled[i];
      if (inp._coords) {
        points.push(inp._coords);
      } else {
        setStatus(`Locating stop ${i + 1} of ${filled.length}\u2026`, false);
        const p = await geocode(inp.value);
        points.push(p);
        if (i < filled.length - 1) await sleep(250);
      }
    }

    let totalMeters = 0;
    const legs = [];
    for (var j = 0; j < points.length - 1; j++) {
      setStatus(`Calculating leg ${j + 1} of ${points.length - 1}\u2026`, false);
      const meters = await routeMeters(points[j], points[j + 1]);
      totalMeters += meters;
      legs.push({ from: points[j].query, to: points[j + 1].query, meters });
      if (j < points.length - 2) await sleep(150);
    }

    const totalMiles = milesFromMeters(totalMeters);

    let html = `<div class="card" style="margin-top:1rem;">
      <p style="font-size:1.2rem;"><strong>Total distance:</strong> ${fmtMiles(totalMiles)}</p>
      <p class="small muted">Driving miles based on public road routing data.</p>
      <hr style="border:0;border-top:1px solid var(--color-border,#333);margin:1rem 0;" />
      <strong>Legs:</strong>
      <ul>`;

    for (const leg of legs) {
      html += `<li>${escapeHtml(leg.from)} &rarr; ${escapeHtml(leg.to)}: <strong>${fmtMiles(milesFromMeters(leg.meters))}</strong></li>`;
    }

    html += `</ul></div>`;
    renderOutput(html);
    setStatus("Done.", false);
  } catch (err) {
    setStatus(err.message || "Something went wrong.", true);
  }
}

document.getElementById("addStop").addEventListener("click", function () { addStop(""); });
document.getElementById("calc").addEventListener("click", calculate);

addStop("");
addStop("");

})();
</script>
