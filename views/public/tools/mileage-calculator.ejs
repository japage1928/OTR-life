<section class="panel">
  <h1>Multi-Stop Mileage Calculator</h1>
  <p class="muted">
    Enter cities, states, or ZIP codes to get real driving miles across multiple stops.
    Add as many stops as you need — it calculates each leg and the total.
  </p>
</section>

<section class="card">
  <% if (!hasMapbox) { %>
    <div class="alert error"><p>Mileage calculator is not configured. Please contact the site admin.</p></div>
  <% } else { %>
    <div id="stops" class="stack" style="margin-bottom:1rem;"></div>

    <div class="row gap" style="margin-bottom:1rem;">
      <button class="btn btn-outline" id="addStop" type="button">+ Add Stop</button>
      <button class="btn" id="calc" type="button">Calculate Miles</button>
    </div>

    <p id="status" class="small muted"></p>
    <div id="output"></div>
  <% } %>
</section>

<section class="card">
  <h2>Tips</h2>
  <p><strong>What format should I use?</strong><br />City and state works best (e.g., "Dallas, TX" or "Dallas TX"). ZIP codes also work.</p>
  <p><strong>How accurate is it?</strong><br />Miles come from real road routing data, so they reflect actual driving distance — not straight-line miles.</p>
  <p><strong>Can I add more than two stops?</strong><br />Yes. Hit "Add Stop" for each additional waypoint. The tool calculates every leg and adds them up.</p>
  <p><strong>Does it account for my specific route?</strong><br />It finds the fastest car route between each stop. Truck-restricted roads may differ slightly.</p>
</section>

<style>
  .stop-wrap { position: relative; flex: 1; }
  #stops .row { display: flex; gap: .5rem; align-items: flex-start; }
  #stops .row button { white-space: nowrap; margin-top: 2px; }
  #output ul { padding-left: 1.2rem; margin: .5rem 0 0; }
  #output li { margin-bottom: .25rem; }
  #status.error { color: var(--color-danger, #e55); }

  .ac-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--color-surface, #1e1e1e);
    border: 1px solid var(--color-border, #444);
    border-top: none;
    border-radius: 0 0 6px 6px;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(0,0,0,.45);
  }
  .ac-dropdown li {
    list-style: none;
    padding: .5rem .75rem;
    font-size: .9rem;
    cursor: pointer;
    border-bottom: 1px solid var(--color-border, #333);
    line-height: 1.3;
  }
  .ac-dropdown li:last-child { border-bottom: none; }
  .ac-dropdown li:hover,
  .ac-dropdown li.ac-active { background: var(--color-primary, #c8952a); color: #fff; }
</style>

<% if (hasMapbox) { %>
<script>
(function () {

var OSRM_URL = "https://router.project-osrm.org/route/v1/driving";
var AC_DEBOUNCE  = 350;
var AC_MIN_CHARS = 2;

function milesFromMeters(m) { return m / 1609.344; }
function fmtMiles(mi) { return mi.toFixed(1) + " mi"; }

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, function (c) {
    return {"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c];
  });
}

function shortLabel(placeName) {
  if (!placeName) return "";
  var parts = placeName.split(",").map(function (p) { return p.trim(); });
  var filtered = parts.filter(function (p) {
    return p !== "United States" && p !== "USA";
  });
  if (filtered.length >= 2) {
    return filtered[0] + ", " + filtered[filtered.length - 1];
  }
  return filtered[0] || placeName;
}

function setStatus(msg, isError) {
  var el = document.getElementById("status");
  el.textContent = msg;
  el.className = "small" + (isError ? " error" : " muted");
}

function renderOutput(html) {
  document.getElementById("output").innerHTML = html;
}

function closeAllDropdowns(except) {
  document.querySelectorAll(".ac-dropdown").forEach(function (dd) {
    if (dd !== except) dd.remove();
  });
}

document.addEventListener("mousedown", function (e) {
  if (!e.target.closest(".stop-wrap")) closeAllDropdowns(null);
});

async function mapboxAutocomplete(query) {
  var res = await fetch("/tools/api/places?q=" + encodeURIComponent(query), { headers: { Accept: "application/json" } });
  if (!res.ok) return [];
  var data = await res.json();
  return Array.isArray(data) ? data : [];
}

async function mapboxGeocode(query) {
  var res = await fetch("/tools/api/geocode?q=" + encodeURIComponent(query), { headers: { Accept: "application/json" } });
  if (!res.ok) {
    var err = await res.json().catch(function () { return {}; });
    throw new Error(err.error || "Could not find location: \"" + query + "\"");
  }
  var data = await res.json();
  return { query: data.label, lat: data.lat, lon: data.lon };
}

async function routeMeters(a, b) {
  var coords = a.lon + "," + a.lat + ";" + b.lon + "," + b.lat;
  var url = OSRM_URL + "/" + coords + "?overview=false&alternatives=false&steps=false";
  var res = await fetch(url, { headers: { Accept: "application/json" } });
  if (!res.ok) throw new Error("Routing failed: \"" + a.query + "\" to \"" + b.query + "\"");
  var data = await res.json();
  if (!data || data.code !== "Ok" || !data.routes || !data.routes.length) {
    throw new Error("No route found: \"" + a.query + "\" to \"" + b.query + "\"");
  }
  return data.routes[0].distance;
}

function sleep(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }

function attachAutocomplete(input) {
  var timer = null;
  var activeIndex = -1;

  function getDropdown() { return input.parentElement.querySelector(".ac-dropdown"); }

  function removeDropdown() {
    var dd = getDropdown();
    if (dd) dd.remove();
    activeIndex = -1;
  }

  function buildDropdown(features) {
    removeDropdown();
    if (!features.length) return;

    var ul = document.createElement("ul");
    ul.className = "ac-dropdown";

    features.forEach(function (feat, idx) {
      var label = shortLabel(feat.place_name);
      var li = document.createElement("li");
      li.textContent = label;

      li.addEventListener("mousedown", function (e) {
        e.preventDefault();
        input.value = label;
        input._coords = { lat: feat.center[1], lon: feat.center[0], query: label };
        removeDropdown();
        input.focus();
      });

      ul.appendChild(li);
    });

    input.parentElement.appendChild(ul);
    activeIndex = -1;
  }

  function highlight(newIndex) {
    var dd = getDropdown();
    if (!dd) return;
    var items = dd.querySelectorAll("li");
    items.forEach(function (li, i) { li.classList.toggle("ac-active", i === newIndex); });
    activeIndex = newIndex;
  }

  input.addEventListener("input", function () {
    var val = input.value.trim();
    if (input._coords && val !== input._coords.query) {
      delete input._coords;
    }
    clearTimeout(timer);
    if (val.length < AC_MIN_CHARS) { removeDropdown(); return; }
    timer = setTimeout(async function () {
      try {
        var features = await mapboxAutocomplete(val);
        if (input.value.trim() === val) buildDropdown(features);
      } catch (_) { removeDropdown(); }
    }, AC_DEBOUNCE);
  });

  input.addEventListener("keydown", function (e) {
    var dd = getDropdown();
    if (!dd) return;
    var items = dd.querySelectorAll("li");
    if (e.key === "ArrowDown") {
      e.preventDefault();
      highlight(Math.min(activeIndex + 1, items.length - 1));
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      highlight(Math.max(activeIndex - 1, 0));
    } else if (e.key === "Enter" && activeIndex >= 0) {
      e.preventDefault();
      items[activeIndex].dispatchEvent(new MouseEvent("mousedown", { bubbles: true }));
    } else if (e.key === "Escape") {
      removeDropdown();
    }
  });

  input.addEventListener("blur", function () {
    setTimeout(removeDropdown, 150);
  });
}

var stopCount = 0;

function addStop(value) {
  stopCount += 1;

  var row = document.createElement("div");
  row.className = "row";
  row.dataset.stopRow = "1";

  var wrap = document.createElement("div");
  wrap.className = "stop-wrap";

  var input = document.createElement("input");
  input.type = "text";
  input.placeholder = stopCount === 1 ? "Start (city, state or ZIP)" :
                      stopCount === 2 ? "Destination" :
                      "Stop " + stopCount;
  input.value = value || "";
  wrap.appendChild(input);
  attachAutocomplete(input);

  var remove = document.createElement("button");
  remove.type = "button";
  remove.textContent = "Remove";
  remove.className = "btn btn-sm btn-outline";
  remove.addEventListener("click", function () { row.remove(); renumber(); });

  row.appendChild(wrap);
  row.appendChild(remove);
  document.getElementById("stops").appendChild(row);
  updateRemove();
}

function getInputs() {
  return Array.from(document.querySelectorAll('[data-stop-row="1"] input'));
}

function updateRemove() {
  var rows = Array.from(document.querySelectorAll('[data-stop-row="1"]'));
  var can = rows.length > 2;
  rows.forEach(function (row) {
    var btn = row.querySelector("button");
    btn.disabled = !can;
    btn.style.opacity = can ? "1" : "0.4";
    btn.style.cursor  = can ? "pointer" : "not-allowed";
  });
}

function renumber() {
  var inputs = getInputs();
  inputs.forEach(function (inp, idx) {
    if (idx === 0) inp.placeholder = "Start (city, state or ZIP)";
    else if (idx === inputs.length - 1) inp.placeholder = "Destination";
    else inp.placeholder = "Stop " + (idx + 1);
  });
  updateRemove();
}

async function calculate() {
  closeAllDropdowns(null);
  renderOutput("");
  setStatus("Working\u2026", false);

  var inputs = getInputs().filter(function (i) { return i.value.trim(); });
  if (inputs.length < 2) {
    setStatus("Add at least a start and one destination.", true);
    return;
  }

  try {
    var points = [];
    for (var i = 0; i < inputs.length; i++) {
      var inp = inputs[i];
      if (inp._coords) {
        points.push(inp._coords);
      } else {
        setStatus("Locating stop " + (i + 1) + " of " + inputs.length + "\u2026", false);
        var p = await mapboxGeocode(inp.value);
        points.push(p);
        if (i < inputs.length - 1) await sleep(100);
      }
    }

    var totalMeters = 0;
    var legs = [];
    for (var j = 0; j < points.length - 1; j++) {
      setStatus("Calculating leg " + (j + 1) + " of " + (points.length - 1) + "\u2026", false);
      var meters = await routeMeters(points[j], points[j + 1]);
      totalMeters += meters;
      legs.push({ from: points[j].query, to: points[j + 1].query, meters: meters });
      if (j < points.length - 2) await sleep(100);
    }

    var totalMiles = milesFromMeters(totalMeters);
    var html = '<div class="card" style="margin-top:1rem;">' +
      '<p style="font-size:1.2rem;"><strong>Total distance:</strong> ' + fmtMiles(totalMiles) + '</p>' +
      '<p class="small muted">Driving miles based on public road routing data.</p>' +
      '<hr style="border:0;border-top:1px solid var(--color-border,#333);margin:1rem 0;" />' +
      '<strong>Legs:</strong><ul>';

    legs.forEach(function (leg) {
      html += "<li>" + escapeHtml(leg.from) + " &rarr; " + escapeHtml(leg.to) +
        ": <strong>" + fmtMiles(milesFromMeters(leg.meters)) + "</strong></li>";
    });

    html += "</ul></div>";
    renderOutput(html);
    setStatus("Done.", false);
  } catch (err) {
    setStatus(err.message || "Something went wrong.", true);
  }
}

document.getElementById("addStop").addEventListener("click", function () { addStop(""); });
document.getElementById("calc").addEventListener("click", calculate);

addStop("");
addStop("");

})();
</script>
<% } %>
