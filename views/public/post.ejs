<article class="panel post-detail">
  <p style="margin-bottom: 1rem;"><a href="/posts" class="btn btn-outline" style="display: inline-block;">← All Posts</a></p>
  
  <% if (post.category_name) { %>
    <p class="muted" style="margin: 0 0 0.5rem 0;"><a href="/category/<%= post.category_slug %>"><%= post.category_name %></a></p>
  <% } %>
  
  <h1 style="margin-top: 0;"><%= post.title %></h1>
  <p class="muted"><%= formatDate(post.published_at) %></p>
  
  <% if (post.cover_image) { %>
    <img src="<%= post.cover_image %>" alt="<%= post.title %>" class="cover" style="max-width: 100%; max-height: 400px; object-fit: cover;" />
  <% } %>
  
  <div class="markdown" style="margin: 2rem 0; line-height: 1.8;"><%- html %></div>

  <% if (tags && tags.length) { %>
    <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--line);">
      <h3>Tags</h3>
      <div class="chip-row">
        <% tags.forEach((tag) => { %>
          <a class="chip" href="/tag/<%= tag.slug %>"><%= tag.name %></a>
        <% }) %>
      </div>
    </div>
  <% } %>
</article>