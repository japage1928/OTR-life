<section class="panel">
  <h1>Get In Touch</h1>
  <p class="muted">Questions, corrections, topic suggestions, or partnership inquiries. We read and reply to all messages.</p>

  <% if (success) { %>
    <div class="alert success" style="margin: 1.5rem 0;">
      <strong>Message sent!</strong> Thank you for reaching out. We'll get back to you as soon as possible.
    </div>
  <% } %>

  <% if (errors && errors.length) { %>
    <div class="alert error" style="margin: 1.5rem 0;">
      <strong>Please fix the following:</strong>
      <ul style="margin: 0.5rem 0 0; padding-left: 1.5rem;">
        <% errors.forEach((error) => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form class="stack" method="post" action="/contact" style="margin-top: 2rem;">
    <div>
      <label for="name">Name</label>
      <input type="text" id="name" name="name" value="<%= formData.name %>" required maxlength="80" placeholder="Your name" />
    </div>
    <div>
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= formData.email %>" required maxlength="120" placeholder="your@email.com" />
    </div>
    <div>
      <label for="subject">Subject</label>
      <input type="text" id="subject" name="subject" value="<%= formData.subject %>" required maxlength="120" placeholder="What's this about?" />
    </div>
    <div>
      <label for="body">Message</label>
      <textarea id="body" name="body" rows="10" required maxlength="5000" placeholder="Your message here..."><%= formData.body %></textarea>
    </div>
    <button class="btn" type="submit">Send Message</button>
  </form>
</section>