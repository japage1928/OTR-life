<section class="hero home-hero">
  <h1>Drive smarter. Rest better. Stay road-ready.</h1>
  <p>
    Long-haul life needs practical guidance. OTR Life brings no-nonsense advice on truck setup, money, food, and routines
    that actually hold up mile after mile.
  </p>
  <a class="btn" href="/posts">Start Here</a>
</section>

<section class="home-section">
  <h2 class="section-title">Latest Posts</h2>
  <div class="post-stack">
    <% latestPosts.forEach((post) => { %>
      <article class="card post-card-vertical">
        <% if (post.cover_image) { %>
          <img src="<%= post.cover_image %>" alt="<%= post.title %>" class="cover post-cover" />
        <% } else { %>
          <div class="cover post-cover cover-fallback" aria-hidden="true"></div>
        <% } %>

        <% if (post.category_name) { %>
          <a href="/category/<%= post.category_slug %>" class="category-badge"><%= post.category_name %></a>
        <% } %>

        <h3><a href="/post/<%= post.slug %>"><%= post.title %></a></h3>
        <p class="muted"><%= post.excerpt %></p>
        <div class="post-meta-row">
          <a href="/post/<%= post.slug %>" class="read-more-link">Read More</a>
          <span class="muted"><%= formatDate(post.published_at) %></span>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="card author-card">
  <div class="author-avatar" aria-hidden="true">OTR</div>
  <h3>Hi, I&apos;m the OTR Life crew.</h3>
  <p class="muted">
    We publish field-tested guidance for drivers living out of the cab. Everything here is built for real schedules, real
    budgets, and real truck-stop conditions.
  </p>
  <a href="/about" class="read-more-link">Read my story</a>
</section>

<section class="home-section">
  <h2 class="section-title">Popular Now</h2>
  <div class="card popular-list-card">
    <ul class="popular-list">
      <% latestPosts.slice(0, 3).forEach((post) => { %>
        <li>
          <% if (post.cover_image) { %>
            <img src="<%= post.cover_image %>" alt="" class="popular-thumb" />
          <% } %>
          <div>
            <a href="/post/<%= post.slug %>"><%= post.title %></a>
            <p class="muted"><%= formatDate(post.published_at) %></p>
          </div>
        </li>
      <% }) %>
    </ul>
  </div>
</section>

<section class="home-section">
  <h2 class="section-title">Topics</h2>
  <div class="card">
    <div class="chip-row">
      <% featuredCategories.forEach((cat) => { %>
        <a class="chip" href="/category/<%= cat.slug %>"><%= cat.name %> (<%= cat.post_count %>)</a>
      <% }) %>
    </div>
  </div>
</section>
