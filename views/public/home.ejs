<section class="hero home-hero">
  <h1>Drive smarter. Rest better. Stay road-ready.</h1>
  <p><%= settings.tagline || "Long-haul life needs practical guidance that holds up mile after mile." %></p>
  <a class="btn" href="/posts">Start Here</a>
</section>

<div class="home-layout">

  <aside class="home-sidebar">
    <h2 class="section-title" style="margin-bottom:1.1rem;">Driver Tools</h2>
    <div class="home-sidebar-tools">

      <article class="card tool-card-mini">
        <h3>Mileage Calculator</h3>
        <p class="muted">Real road miles across multiple stops — city, state, or ZIP.</p>
        <a class="btn btn-outline btn-sm" href="/tools/mileage-calculator">Open Tool</a>
      </article>

      <article class="card tool-card-mini">
        <h3>Fuel Cost Estimator</h3>
        <p class="muted">Gallons used, total spend, and cost-per-mile before you roll.</p>
        <a class="btn btn-outline btn-sm" href="/tools/fuel-cost">Open Tool</a>
      </article>

      <article class="card tool-card-mini">
        <h3>ETA + Time Zone Helper</h3>
        <p class="muted">Departure time, drive hours, breaks — get your arrival across zones.</p>
        <a class="btn btn-outline btn-sm" href="/tools/eta-timezone">Open Tool</a>
      </article>

      <article class="card tool-card-mini">
        <h3>Route Log Converter</h3>
        <p class="muted">Paste rough trip notes and get a clean log ready to copy.</p>
        <a class="btn btn-outline btn-sm" href="/tools/route-log">Open Tool</a>
      </article>

      <a class="btn btn-outline" href="/tools" style="text-align:center;">All Tools &rarr;</a>
    </div>
  </aside>

  <section>
    <h2 class="section-title" style="margin-bottom:1.1rem;">Latest Articles</h2>
    <% if (latestPosts.length === 0) { %>
      <p class="muted">No posts yet. Check back soon.</p>
    <% } else { %>
      <div class="home-article-list">
        <% latestPosts.forEach((post) => { %>
          <article class="home-article-item">
            <div class="home-article-meta">
              <span class="small muted"><%= formatDate(post.published_at) %></span>
              <% if (post.category_name) { %>
                <a href="/category/<%= post.category_slug %>" class="category-badge"><%= post.category_name %></a>
              <% } %>
            </div>
            <h3><a href="/post/<%= post.slug %>"><%= post.title %></a></h3>
            <% if (post.excerpt) { %>
              <p class="excerpt"><%= post.excerpt %></p>
            <% } %>
            <a href="/post/<%= post.slug %>" class="read-more-link small">Read More &rarr;</a>
          </article>
        <% }) %>
      </div>
      <div style="margin-top:1.25rem;">
        <a class="btn btn-outline" href="/posts">All Articles &rarr;</a>
      </div>
    <% } %>
  </section>

</div>

<section class="card author-card">
  <% if (settings.about_image_url) { %>
    <img src="<%= settings.about_image_url %>" alt="<%= settings.about_title %>" class="author-photo" />
  <% } else { %>
    <div class="author-avatar" aria-hidden="true">OTR</div>
  <% } %>
  <h3><%= settings.about_title || "About OTR Life" %></h3>
  <p class="muted"><%= aboutPreview || "Field-tested guidance for real schedules, budgets, and truck-stop conditions." %></p>
  <a href="/about" class="read-more-link">Read my story</a>
</section>

<section class="home-section">
  <h2 class="section-title">Topics</h2>
  <div class="card">
    <div class="chip-row">
      <% featuredCategories.forEach((cat) => { %>
        <a class="chip" href="/category/<%= cat.slug %>"><%= cat.name %> (<%= cat.post_count %>)</a>
      <% }) %>
    </div>
  </div>
</section>
