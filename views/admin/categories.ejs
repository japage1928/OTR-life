<section class="admin-panel">
  <h1>Categories</h1>
  <% if (errors.length) { %><div class="alert error"><%= errors[0] %></div><% } %>

  <form class="row gap" method="post" action="/admin/categories/create">
    <input type="text" name="name" placeholder="Name" required />
    <input type="text" name="slug" placeholder="Slug (optional)" />
    <button class="btn" type="submit">Add Category</button>
  </form>

  <div class="table-wrap">
    <table>
      <thead><tr><th>Name</th><th>Slug</th><th>Actions</th></tr></thead>
      <tbody>
      <% categories.forEach((cat) => { %>
        <tr>
          <td>
            <form class="row gap" method="post" action="/admin/categories/<%= cat.id %>/update">
              <input type="text" name="name" value="<%= cat.name %>" required />
          </td>
          <td><input type="text" name="slug" value="<%= cat.slug %>" /></td>
          <td class="actions">
              <button class="btn btn-outline" type="submit">Save</button>
            </form>
            <form method="post" action="/admin/categories/<%= cat.id %>/delete" data-confirm="Delete this category?">
              <button class="btn btn-danger" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>