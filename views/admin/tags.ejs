<section class="admin-panel">
  <h1>Tags</h1>
  <% if (errors.length) { %><div class="alert error"><%= errors[0] %></div><% } %>

  <form class="row gap" method="post" action="/admin/tags/create">
    <input type="text" name="name" placeholder="Name" required />
    <input type="text" name="slug" placeholder="Slug (optional)" />
    <button class="btn" type="submit">Add Tag</button>
  </form>

  <div class="table-wrap">
    <table>
      <thead><tr><th>Name</th><th>Slug</th><th>Actions</th></tr></thead>
      <tbody>
      <% tags.forEach((tag) => { %>
        <tr>
          <td>
            <form class="row gap" method="post" action="/admin/tags/<%= tag.id %>/update">
              <input type="text" name="name" value="<%= tag.name %>" required />
          </td>
          <td><input type="text" name="slug" value="<%= tag.slug %>" /></td>
          <td class="actions">
              <button class="btn btn-outline" type="submit">Save</button>
            </form>
            <form method="post" action="/admin/tags/<%= tag.id %>/delete" data-confirm="Delete this tag?">
              <button class="btn btn-danger" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>