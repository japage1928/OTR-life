<section class="admin-panel">
  <h1><%= post && post.id ? 'Edit Post' : 'New Post' %></h1>

  <% if (errors.length) { %>
    <div class="alert error">
      <ul>
      <% errors.forEach((error) => { %><li><%= error %></li><% }) %>
      </ul>
    </div>
  <% } %>

  <form class="stack" method="post" action="<%= post && post.id ? '/admin/posts/' + post.id + '/edit' : '/admin/posts/new' %>">
    <label>Title
      <input id="title-input" type="text" name="title" value="<%= post?.title || '' %>" required />
    </label>
    <label>Slug
      <input id="slug-input" type="text" name="slug" value="<%= post?.slug || '' %>" />
    </label>
    <label>Excerpt
      <textarea name="excerpt" rows="3" required><%= post?.excerpt || '' %></textarea>
    </label>
    <label>Content (Markdown)
      <textarea name="content_md" rows="14" required><%= post?.content_md || '' %></textarea>
    </label>

    <div class="cover-image-field">
      <label>Cover Image</label>

      <% const existingImage = post?.cover_image || ''; %>
      <% if (existingImage) { %>
        <div id="img-preview-wrap" style="margin-bottom:.6rem;">
          <img id="img-preview" src="<%= existingImage %>" alt="Current cover image"
            style="max-width:100%;max-height:200px;border-radius:6px;border:1px solid var(--color-border,#333);" />
        </div>
      <% } else { %>
        <div id="img-preview-wrap" style="margin-bottom:.6rem;display:none;">
          <img id="img-preview" src="" alt="Cover image preview"
            style="max-width:100%;max-height:200px;border-radius:6px;border:1px solid var(--color-border,#333);" />
        </div>
      <% } %>

      <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;margin-bottom:.4rem;">
        <label class="btn btn-sm" style="cursor:pointer;margin:0;">
          Upload from device
          <input id="img-file-input" type="file" accept="image/jpeg,image/png,image/webp,image/gif"
            style="position:absolute;width:1px;height:1px;opacity:0;overflow:hidden;" />
        </label>
        <span id="img-upload-status" style="font-size:.85em;"></span>
      </div>

      <label style="font-size:.85em;color:var(--color-muted,#aaa);margin-top:.2rem;">
        Or paste an image URL
        <input type="url" id="cover-image-url-input" placeholder="https://example.com/photo.jpg"
          value="<%= existingImage.startsWith('/media/') ? '' : existingImage %>" />
      </label>

      <input type="hidden" name="cover_image" id="cover-image-hidden"
        value="<%= existingImage %>" />
    </div>

    <div class="row gap">
      <label>Status
        <select name="status">
          <option value="draft" <%= (post?.status || 'draft') === 'draft' ? 'selected' : '' %>>Draft</option>
          <option value="published" <%= post?.status === 'published' ? 'selected' : '' %>>Published</option>
        </select>
      </label>
      <label>Publish date
        <input type="datetime-local" name="published_at" id="published-at-input"
          value="<%= post?.published_at ? post.published_at.slice(0,16) : '' %>" />
      </label>
    </div>

    <div>
      <label>Category
        <select id="category-select" name="category_id">
          <option value="">No category</option>
          <% categories.forEach((cat) => { %>
            <option value="<%= cat.id %>" <%= Number(post?.category_id) === cat.id ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
      </label>
      <div class="quick-add-row" style="display:flex;gap:.5rem;margin-top:.4rem;align-items:center;">
        <input id="new-category-input" type="text" placeholder="New category name" style="flex:1;" />
        <button type="button" id="add-category-btn" class="btn btn-sm">+ Add</button>
        <span id="category-msg" style="font-size:.85em;"></span>
      </div>
    </div>

    <div>
      <label>Tags (multi-select)
        <select id="tags-select" name="tag_ids" multiple size="8">
          <% tags.forEach((tag) => { %>
            <option value="<%= tag.id %>" <%= selectedTagIds.includes(tag.id) ? 'selected' : '' %>><%= tag.name %></option>
          <% }) %>
        </select>
      </label>
      <div class="quick-add-row" style="display:flex;gap:.5rem;margin-top:.4rem;align-items:center;">
        <input id="new-tag-input" type="text" placeholder="New tag name" style="flex:1;" />
        <button type="button" id="add-tag-btn" class="btn btn-sm">+ Add</button>
        <span id="tag-msg" style="font-size:.85em;"></span>
      </div>
    </div>

    <h3>SEO</h3>
    <label>Meta Title
      <input type="text" name="meta_title" value="<%= post?.meta_title || '' %>" />
    </label>
    <label>Meta Description
      <textarea name="meta_description" rows="3"><%= post?.meta_description || '' %></textarea>
    </label>

    <button class="btn" type="submit">Save Post</button>
  </form>
</section>

<script>
(function () {
  function showMsg(el, text, isError) {
    el.textContent = text;
    el.style.color = isError ? 'var(--color-danger, #e55)' : 'var(--color-success, #5a5)';
    setTimeout(function () { el.textContent = ''; }, 4000);
  }

  var fileInput = document.getElementById('img-file-input');
  var urlInput  = document.getElementById('cover-image-url-input');
  var hidden    = document.getElementById('cover-image-hidden');
  var preview   = document.getElementById('img-preview');
  var previewWrap = document.getElementById('img-preview-wrap');
  var statusEl  = document.getElementById('img-upload-status');

  function showPreview(src) {
    preview.src = src;
    previewWrap.style.display = '';
  }

  fileInput.addEventListener('change', async function () {
    var file = this.files[0];
    if (!file) return;
    statusEl.textContent = 'Uploading\u2026';
    statusEl.style.color = 'var(--color-muted, #aaa)';

    var formData = new FormData();
    formData.append('image', file);

    try {
      var res = await fetch('/admin/api/upload-image', { method: 'POST', body: formData });
      var data = await res.json();
      if (!res.ok) { showMsg(statusEl, data.error || 'Upload failed.', true); return; }
      hidden.value = data.url;
      urlInput.value = '';
      showPreview(data.url);
      showMsg(statusEl, 'Uploaded!', false);
    } catch (e) {
      showMsg(statusEl, 'Network error during upload.', true);
    }
  });

  urlInput.addEventListener('input', function () {
    var val = this.value.trim();
    hidden.value = val;
    if (val) {
      showPreview(val);
    } else {
      previewWrap.style.display = 'none';
      preview.src = '';
    }
  });

  document.getElementById('add-category-btn').addEventListener('click', async function () {
    var input = document.getElementById('new-category-input');
    var msg = document.getElementById('category-msg');
    var name = input.value.trim();
    if (!name) { showMsg(msg, 'Enter a name.', true); return; }
    this.disabled = true;
    try {
      var res = await fetch('/admin/api/categories/quick-create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name })
      });
      var data = await res.json();
      if (!res.ok) { showMsg(msg, data.error || 'Error.', true); return; }
      var select = document.getElementById('category-select');
      var opt = new Option(data.name, data.id, true, true);
      select.appendChild(opt);
      input.value = '';
      showMsg(msg, '"' + data.name + '" added and selected.', false);
    } catch (e) {
      showMsg(msg, 'Network error.', true);
    } finally {
      this.disabled = false;
    }
  });

  document.getElementById('new-category-input').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); document.getElementById('add-category-btn').click(); }
  });

  document.getElementById('add-tag-btn').addEventListener('click', async function () {
    var input = document.getElementById('new-tag-input');
    var msg = document.getElementById('tag-msg');
    var name = input.value.trim();
    if (!name) { showMsg(msg, 'Enter a name.', true); return; }
    this.disabled = true;
    try {
      var res = await fetch('/admin/api/tags/quick-create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name })
      });
      var data = await res.json();
      if (!res.ok) { showMsg(msg, data.error || 'Error.', true); return; }
      var select = document.getElementById('tags-select');
      var opt = new Option(data.name, data.id, true, true);
      select.appendChild(opt);
      input.value = '';
      showMsg(msg, '"' + data.name + '" added and selected.', false);
    } catch (e) {
      showMsg(msg, 'Network error.', true);
    } finally {
      this.disabled = false;
    }
  });

  document.getElementById('new-tag-input').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); document.getElementById('add-tag-btn').click(); }
  });
})();
</script>
